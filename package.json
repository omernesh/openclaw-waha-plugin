{
  "name": "waha-openclaw-channel",
  "version": "1.15.3",
  "description": "OpenClaw WAHA (WhatsApp HTTP API) channel plugin",
  "type": "module",
  "main": "./index.ts",
  "files": [
    "index.ts",
    "src/",
    "!src/**/*.bak*",
    "dist/admin/",
    "docs/",
    "!docs/extra phase/",
    "SKILL.md",
    "config-example.json",
    "README.md",
    "CHANGELOG.md",
    "openclaw.plugin.json",
    "rules/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/omernesh/openclaw-waha-plugin.git"
  },
  "keywords": [
    "openclaw",
    "waha",
    "whatsapp",
    "channel",
    "plugin"
  ],
  "author": "Omer Nesher",
  "license": "CC-BY-NC-4.0",
  "scripts": {
    "test": "vitest run --reporter=verbose",
    "build:admin": "vite build --config vite.admin.config.ts",
    "dev:admin": "vite --config vite.admin.config.ts",
    "build": "npm run build:admin"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "waha",
      "label": "WAHA",
      "selectionLabel": "WAHA (WhatsApp HTTP API)",
      "docsPath": "/channels/whatsapp",
      "docsLabel": "whatsapp",
      "blurb": "Self-hosted WhatsApp via WAHA webhooks + REST API bridge.",
      "order": 70,
      "aliases": [
        "whatsapp-waha",
        "waha-whatsapp"
      ],
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "waha-openclaw-channel",
      "localPath": "skills/waha-openclaw-channel",
      "defaultChoice": "local"
    }
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lru-cache": "^11.2.6",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  }
}
